GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_API_URL=https://api.github.com
GEMINI_API_KEY=your_google_gemini_api_key_here
# For local MongoDB use:
MONGODB_URL=mongodb://localhost:27017
# For MongoDB Atlas (recommended): set the full connection string, for example:
# MONGODB_URL=mongodb+srv://<username>:<password>@cluster0.mongodb.net/github_dashboard?retryWrites=true&w=majority
# Or provide the base URI without credentials and set user/password below. The app will
# insert credentials into the URI when `MONGODB_USER` and `MONGODB_PASSWORD` are set.
DATABASE_NAME=github_dashboard
MONGODB_USER=
MONGODB_PASSWORD=
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:3000
SECRET_KEY=your-secret-key-change-in-production-use-strong-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
